  --shadow-brutal: 6px 6px 0 #0F0F0F;
  --shadow-brutal-sm: 4px 4px 0 #0F0F0F;
  --shadow-brutal-hover: 2px 2px 0 #0F0F0F;
  --shadow-brutal-xs: 2px 2px 0 #0F0F0F;
  --shadow-brutal-accent: 6px 6px 0 #FF3A00;

  --bg-inverted: #0F0F0F;
  --text-on-inverted: #FFFFFF;

  --status-error-bg: #FEF2F2;
  --status-error-text: #991B1B;
  --status-error-border: #FEE2E2;
  --status-success-bg: #F0FDF4;
  --status-success-text: #166534;
  --status-warning-bg: #FFF7ED;
  --status-warning-text: #92400E;

  --dot-pattern: radial-gradient(rgba(0, 0, 0, 0.06) 1.5px, transparent 1.5px);
}

[data-theme="dark"] {
  --background: #0F0F0F;
  --foreground: #FFFFFF;

  --bg-inverted: #262626;
  --text-on-inverted: #FFFFFF;

  --bg-surface: hsl(14, 4%, 10%);
  --bg-surface-light: hsl(14, 4%, 15%);
  --bg-pill: hsl(14, 4%, 15%);
  --bg-pill-hover: hsl(14, 4%, 23%);
  --border-hard: hsl(14, 10%, 45%);
  --border-subtle: hsl(14, 6%, 24%);

  --text-muted: hsl(14, 8%, 58%);
  --text-muted-soft: hsl(14, 6%, 48%);
  --text-secondary: hsl(14, 8%, 62%);
  --text-tertiary: hsl(14, 6%, 78%);

  --badge-bronze: #A0522D;
  --badge-silver: #A9A9A9;
  --badge-gold: #FFD700;
  --badge-diamond: #FF3A00;

  --hm-0: hsl(14, 4%, 23%);
  --hm-1: #6b3a1a;
  --hm-2: #b5501e;
  --hm-3: #FF6A40;
  --hm-4: #FF3A00;

  --shadow-brutal: 6px 6px 0 #000000;
  --shadow-brutal-sm: 4px 4px 0 #000000;
  --shadow-brutal-hover: 2px 2px 0 #000000;
  --shadow-brutal-xs: 2px 2px 0 #000000;
  --shadow-brutal-accent: 6px 6px 0 #FF3A00;

  --status-error-bg: #3B1111;
  --status-error-text: #FCA5A5;
  --status-error-border: #7F1D1D;
  --status-success-bg: #052E16;
  --status-success-text: #86EFAC;
  --status-warning-bg: #431407;
  --status-warning-text: #FED7AA;

  --dot-pattern: radial-gradient(rgba(255, 255, 255, 0.06) 1.5px, transparent 1.5px);
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-space-grotesk);
  --font-mono: var(--font-jetbrains-mono);
}

body {
  background-color: var(--background);
  background-image: var(--dot-pattern);
  background-size: 24px 24px;
  color: var(--foreground);
  font-family: var(--font-sans), system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: var(--background);
}

::-webkit-scrollbar-thumb {
  background: var(--foreground);
  border: 2px solid var(--background);
}

::-webkit-scrollbar-thumb:hover {
  background: var(--bg-pill-hover);
}

html {
  scroll-behavior: smooth;
}

/* Brutalist button base */
.btn-brutal {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border: 2px solid var(--border-hard);
  box-shadow: var(--shadow-brutal);
  transition: transform 0.15s, box-shadow 0.15s;
  cursor: pointer;
}

.btn-brutal:hover {
  transform: translate(2px, 2px);
  box-shadow: var(--shadow-brutal-hover);
}

.btn-brutal-primary {
  background-color: var(--accent);
  color: #FFFFFF;
}

.btn-brutal-secondary {
  background-color: var(--bg-surface);
  color: var(--foreground);
}

.btn-brutal-dark {
  background-color: var(--bg-inverted);
  color: var(--text-on-inverted);
}

/* Flat button variant — no shadow, for use inside cards */
.btn-brutal-flat {
  box-shadow: none;
}
.btn-brutal-flat:hover {
  transform: none;
  box-shadow: none;
  opacity: 0.85;
}

/* Brutalist card */
.card-brutal {
  background: var(--bg-surface);
  border: 2px solid var(--border-hard);
  box-shadow: var(--shadow-brutal);
}

/* Brutalist input */
.input-brutal {
  width: 100%;
  padding-top: 0.75rem;
  padding-bottom: 0.75rem;
  padding-left: 1rem;
  padding-right: 1rem;
  border: 2px solid var(--border-hard);
  background: var(--bg-surface);
  color: var(--foreground);
  font-weight: 600;
  font-size: 0.875rem;
}

.input-brutal::placeholder {
  color: var(--text-muted);
  font-weight: 500;
}

.input-brutal:focus {
  outline: none;
  border-color: var(--accent);
}

/* Large accent numbers */
.text-accent-brutal {
  color: var(--accent);
  -webkit-text-stroke: 1px var(--border-hard);
  text-shadow: 2px 2px 0 rgba(0, 0, 0, 0.1);
}

/* Page enter animation */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-16px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes blink {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.3; transform: scale(0.85); }
}

.live-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  background-color: #22c55e;
  border-radius: 50%;
  animation: blink 1.5s ease-in-out infinite;
  box-shadow: 0 0 6px #22c55e;
}

.animate-fade-in-up {
  animation: fadeInUp 0.25s ease-out both;
}

.animate-slide-in-left {
  animation: slideInLeft 0.25s ease-out both;
}

.animate-scale-in {
  animation: scaleIn 0.2s ease-out both;
}

/* Stagger children */
.stagger-children > * {
  animation: fadeInUp 0.25s ease-out both;
}
.stagger-children > *:nth-child(1) { animation-delay: 0ms; }
.stagger-children > *:nth-child(2) { animation-delay: 30ms; }
.stagger-children > *:nth-child(3) { animation-delay: 60ms; }
.stagger-children > *:nth-child(4) { animation-delay: 90ms; }
.stagger-children > *:nth-child(5) { animation-delay: 120ms; }
.stagger-children > *:nth-child(6) { animation-delay: 150ms; }
.stagger-children > *:nth-child(7) { animation-delay: 180ms; }
.stagger-children > *:nth-child(8) { animation-delay: 210ms; }
.stagger-children > *:nth-child(9) { animation-delay: 240ms; }
.stagger-children > *:nth-child(10) { animation-delay: 270ms; }
.stagger-children > *:nth-child(11) { animation-delay: 300ms; }
.stagger-children > *:nth-child(12) { animation-delay: 330ms; }

/* Skeleton loading */
.skeleton {
  background: linear-gradient(90deg, var(--bg-surface-light) 25%, var(--bg-surface) 50%, var(--bg-surface-light) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border: 2px solid var(--border-hard);
}

/* Tooltip */
.tooltip-brutal {
  position: relative;
}
.tooltip-brutal::after {
  content: attr(data-tooltip);
  position: absolute;
  bottom: calc(100% + 8px);
  left: 50%;
  transform: translateX(-50%) scale(0.9);
  padding: 4px 10px;
  background: var(--foreground);
  color: var(--background);
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  white-space: nowrap;
  border: 2px solid var(--border-hard);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.15s, transform 0.15s;
}
.tooltip-brutal:hover::after {
  opacity: 1;
  transform: translateX(-50%) scale(1);
}

/* Chat fullscreen — hide footer so chat fills viewport */
body:has(.chat-page-wrapper) footer {
  display: none;
}
body:has(.chat-page-wrapper) main {
  min-height: auto !important;
}

/* Focus ring for accessibility */
.input-brutal:focus-visible,
.btn-brutal:focus-visible {
  outline: 3px solid var(--accent);
  outline-offset: 2px;
}

/* Disabled button state */
.btn-brutal:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none !important;
  box-shadow: var(--shadow-brutal) !important;
}

/* Settings "New" field pulse — used when landing on /settings?complete=name */
@keyframes settings-highlight-pulse {
  0%, 100% { outline-color: var(--accent); }
  50% { outline-color: transparent; }
}
.settings-highlight-pulse {
  animation: settings-highlight-pulse 1.6s ease-in-out infinite;
}

/* Respect users who prefer reduced motion — show a static highlight instead */
@media (prefers-reduced-motion: reduce) {
  .settings-highlight-pulse {
    animation: none;
    outline: 3px solid var(--accent);
  }
}
</file>

