                width: 36,
                height: 36,
                borderRadius: "50%",
                border: "2px solid var(--border-hard)",
                backgroundColor: "var(--bg-inverted)",
              }}
            >
              <ProfileAvatar
                avatarUrl={userProfile.avatar_url}
                username={userProfile.username}
