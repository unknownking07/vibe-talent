              <Bot size={12} />
              Contact via Agent
            </Link>
            <Link
              href={`/agent/evaluate/${user.username}`}
              className="btn-brutal btn-brutal-secondary text-xs py-1.5 px-4 flex items-center gap-1"
            >
              Full Report <ArrowRight size={12} />
