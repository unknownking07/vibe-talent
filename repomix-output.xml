                />
              </div>
              <span className="text-sm font-extrabold text-[var(--foreground)] flex items-center gap-1">
                {userProfile.username}
                {userProfile.github_username && (
                  <BadgeCheck
                    size={14}
                    strokeWidth={2.5}
