@import "tailwindcss";

/* Hide scrollbar for horizontal scroll containers */
.scrollbar-hide {
  -ms-overflow-style: none;
  scrollbar-width: none;
}
.scrollbar-hide::-webkit-scrollbar {
  display: none;
}

:root {
  --background: #EAEBEA;
  --foreground: #0F0F0F;

  --bg-surface: #FFFFFF;
  --bg-surface-light: #F5F5F5;
  --bg-pill: #0F0F0F;
  --bg-pill-hover: #2a2a2a;
  --border-hard: #0F0F0F;
  --border-subtle: #D4D4D4;

  --text-muted: #71717A;
  --text-muted-soft: #A1A1AA;
  --text-secondary: #52525B;
  --text-tertiary: #3F3F46;

  --accent: #FF3A00;
  --accent-hover: #E03300;
  --accent-streak: #FF3A00;
  --accent-vibe: #FF3A00;

  --badge-bronze: #D97706;
  --badge-silver: #71717A;
  --badge-gold: #CA8A04;
  --badge-diamond: #0891B2;

  --hm-0: #E5E5E5;
  --hm-1: #FFD4C4;
  --hm-2: #FFA07A;
