          )}
        </div>

        {/* Mobile toggle */}
        <div className="flex items-center gap-2 sm:hidden">
          <ThemeToggle />
          {isLoggedIn && <NotificationBell />}
          {isLoggedIn && userProfile && (
            <Link
              href={`/profile/${userProfile.username}`}
